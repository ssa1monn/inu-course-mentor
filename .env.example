# 이 파일을 .env 로 복사한 뒤 값을 채운다 (cp .env.example .env)
# .env 는 절대 커밋하지 않는다 (.gitignore 처리됨)

# --- PostgreSQL ---
POSTGRES_USER=inucm
POSTGRES_PASSWORD=change_me_in_prod
POSTGRES_DB=inucm

# backend(Prisma)가 사용하는 연결 문자열. docker-compose에서는 host가 db(컨테이너명)
DATABASE_URL=postgresql://inucm:change_me_in_prod@db:5432/inucm?schema=public

# --- 인증 ---
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d

# --- 생성형 AI (Gemini) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# --- NCS 직무능력 API (공공데이터포털, 한국산업인력공단) ---
# data.go.kr/data/15063879 에서 활용신청 후 발급받은 인증키(Encoding)를 넣는다. 비우면 미사용.
NCS_API_KEY=

# --- 백엔드 ---
PORT=4000
NODE_ENV=production
